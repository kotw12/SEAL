# ── SEAL environment ─────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env.

# ── scan engine (default) ────────────────────────────────────────────────
SEAL_RUNNER=engine
# SEAL_ENGINE_BIN=/path/to/engine        # default: on PATH, else standalone binary
SEAL_SCAN_MODE=standard                  # quick | standard | deep
# The scan engine is an external open-source tool (see NOTICE); it runs its
# sandbox in Docker.

# ── per-role models (each independently configurable) ────────────────────
# attack model — the scan engine's model (empty = the engine's own config)
SEAL_ATTACK_MODEL=
# judge model — independent verification (use a DIFFERENT model than the scanner)
SEAL_JUDGE_MODEL=openrouter/anthropic/claude-sonnet-4-6
# orchestrator model — optional LLM that drives evolution (empty = heuristic)
SEAL_ORCHESTRATOR_MODEL=

# ── LLM endpoint + key (shared by judge + orchestrator) ──────────────────
SEAL_USE_LLM_JUDGE=1
# OpenAI-compatible endpoint: OpenRouter directly, or a LiteLLM proxy.
SEAL_JUDGE_URL=http://localhost:4000/v1
OPENROUTER_API_KEY=sk-or-...             # key (or SEAL_JUDGE_API_KEY)

# ── loop control ─────────────────────────────────────────────────────────
SEAL_MAX_ROUNDS=6
SEAL_MAX_DRY_ROUNDS=2
SEAL_COVERAGE_GOAL=0                      # 0 = no early stop on coverage
SEAL_BUDGET_USD=0                         # 0 = unlimited
SEAL_ROUND_TIMEOUT_S=1800
SEAL_WORKDIR=~/.seal/engagements
